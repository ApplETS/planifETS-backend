{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "posthog-node/nestjs": [
        "./node_modules/posthog-node/dist/entrypoints/nestjs"
      ],
      "test/*": [
        "./test/*"
      ],
      "@/common/*": [
        "./src/common/*"
      ],
      "@/utils/*": [
        "./src/common/utils/*"
      ],
      "@/monitoring/*": [
        "./src/monitoring/*"
      ],
    },
    "incremental": true,
    "strict": true,
    "strictBindCallApply": false,
    "typeRoots": [
      "node_modules/@types"
    ],
    "types": [
      "node",
      "jest"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}
